---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout title="About">

<Navbar />

<section class="hero">

  <div class="container">

    <span class="badge">About ReguDocs</span>

    <h1>Making Medical Device Regulatory Affairs Easy to Learn</h1>

    <p>
      ReguDocs is a free learning platform built for students, researchers,
      QA/RA professionals, and medical device manufacturers. Our goal is to
      simplify regulatory affairs through structured learning resources,
      ISO standards, templates, and practical documentation.
    </p>

  </div>

</section>

<section class="mission">

  <div class="container">

    <h2>Our Mission</h2>

    <p class="center">
      To provide high-quality, easy-to-understand regulatory knowledge that
      helps professionals and students succeed in the medical device industry.
    </p>

    <div class="grid">

      <div class="card">
        <h3>📚 Learn</h3>
        <p>
          Beginner to advanced learning roadmap covering regulatory affairs,
          ISO standards, risk management, and clinical evaluation.
        </p>
      </div>

      <div class="card">
        <h3>📄 Templates</h3>
        <p>
          Download ready-to-use SOPs, CER formats, PMS templates,
          checklists, and regulatory documents.
        </p>
      </div>

      <div class="card">
        <h3>🌍 Standards</h3>
        <p>
          Explore ISO, IEC, FDA, EU MDR, and international regulatory
          guidance in one place.
        </p>
      </div>

    </div>

  </div>

</section>

</Layout>

<style>

.hero{
  padding:90px 0;
  background:#eff6ff;
  text-align:center;
}

.container{
  width:min(1200px,90%);
  margin:auto;
}

.badge{
  display:inline-block;
  background:#dbeafe;
  color:#2563eb;
  padding:8px 18px;
  border-radius:30px;
  font-weight:700;
  margin-bottom:20px;
}

.hero h1{
  font-size:58px;
  margin-bottom:20px;
  color:#0f172a;
}

.hero p{
  max-width:850px;
  margin:auto;
  font-size:20px;
  line-height:1.8;
  color:#64748b;
}

.mission{
  padding:90px 0;
}

.mission h2{
  text-align:center;
  font-size:42px;
  margin-bottom:20px;
}

.center{
  text-align:center;
  max-width:750px;
  margin:0 auto 50px;
  color:#64748b;
  font-size:18px;
  line-height:1.7;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:25px;
}

.card{
  background:white;
  padding:35px;
  border-radius:18px;
  box-shadow:0 10px 25px rgba(0,0,0,.08);
  transition:.3s;
}

.card:hover{
  transform:translateY(-8px);
}

.card h3{
  margin-bottom:15px;
  color:#0f172a;
}

.card p{
  color:#64748b;
  line-height:1.7;
}

</style>