</Layout>
<style>

:root{
--primary:#2563eb;
--primary-dark:#1d4ed8;
--bg:#f8fafc;
--card:#ffffff;
--text:#0f172a;
--muted:#64748b;
--border:#e2e8f0;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
font-family:Inter,Arial,sans-serif;
background:var(--bg);
color:var(--text);
line-height:1.7;
}

.container{
width:min(1200px,92%);
margin:auto;
}

.hero{
padding:90px 0;
background:linear-gradient(135deg,#eff6ff,#ffffff);
text-align:center;
}

.badge{
display:inline-block;
padding:8px 18px;
background:#dbeafe;
color:var(--primary);
border-radius:30px;
font-weight:700;
margin-bottom:20px;
}

.hero h1{
font-size:58px;
margin-bottom:20px;
}

.hero p{
max-width:900px;
margin:auto;
font-size:19px;
line-height:1.8;
color:var(--muted);
}

.buttons{
margin-top:40px;
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.primary,
.secondary{

display:inline-block;
padding:14px 28px;
border-radius:10px;
text-decoration:none;
font-weight:700;
transition:.3s;

}

.primary{
background:var(--primary);
color:white;
}

.primary:hover{
background:var(--primary-dark);
transform:translateY(-2px);
}

.secondary{
background:white;
color:var(--text);
border:1px solid var(--border);
}

.secondary:hover{
background:#f1f5f9;
}

section{
padding:80px 0;
}

section h2{
font-size:38px;
margin-bottom:25px;
color:var(--text);
}

section p{
font-size:18px;
color:var(--muted);
line-height:1.9;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
margin-top:35px;
}

.card{
background:var(--card);
padding:30px;
border-radius:18px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
transition:.35s;
}

.card:hover{
transform:translateY(-8px);
}

.card h3{
margin-bottom:15px;
color:var(--text);
}

.card p{
color:var(--muted);
}

.card ul{
padding-left:20px;
margin-top:10px;
}

.card li{
margin-bottom:10px;
}

.timeline{
display:flex;
align-items:center;
justify-content:center;
gap:10px;
flex-wrap:wrap;
margin-top:40px;
}

.step{
background:white;
padding:16px 20px;
border-radius:12px;
font-weight:600;
box-shadow:0 8px 18px rgba(0,0,0,.08);
}

.arrow{
font-size:28px;
color:var(--primary);
font-weight:bold;
}

table{
width:100%;
margin-top:30px;
border-collapse:collapse;
overflow:hidden;
border-radius:12px;
}

th{
background:var(--primary);
color:white;
padding:16px;
text-align:left;
}

td{
padding:16px;
border:1px solid var(--border);
background:white;
}

tr:nth-child(even){
background:#f8fafc;
}

a{
color:var(--primary);
}

ul{
padding-left:20px;
line-height:2;
}

.related .card{
text-decoration:none;
color:inherit;
}

.related .card:hover{
color:var(--primary);
}

@media(max-width:900px){

.hero h1{
font-size:42px;
}

.hero p{
font-size:17px;
}

section h2{
font-size:30px;
}

.timeline{
flex-direction:column;
}

.arrow{
transform:rotate(90deg);
}

table{
display:block;
overflow-x:auto;
white-space:nowrap;
}

}

@media(max-width:600px){

.hero{
padding:70px 0;
}

.hero h1{
font-size:34px;
}

.hero p{
font-size:16px;
}

.buttons{
flex-direction:column;
}

.primary,
.secondary{
width:100%;
text-align:center;
}

.card{
padding:24px;
}

section{
padding:60px 0;
}

}

</style>
