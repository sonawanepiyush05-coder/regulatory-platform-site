<style>

:root{
--primary:#2563eb;
--primary-dark:#1d4ed8;
--bg:#f8fafc;
--card:#ffffff;
--text:#0f172a;
--muted:#64748b;
--border:#e2e8f0;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Inter,Arial,sans-serif;
background:var(--bg);
color:var(--text);
}

.container{
width:min(1200px,92%);
margin:auto;
}

.hero{
padding:90px 0;
background:linear-gradient(135deg,#eff6ff,#ffffff);
text-align:center;
}

.badge{
display:inline-block;
padding:8px 18px;
background:#dbeafe;
color:var(--primary);
border-radius:30px;
font-weight:700;
margin-bottom:20px;
}

.hero h1{
font-size:60px;
margin-bottom:20px;
}

.hero p{
max-width:900px;
margin:auto;
font-size:20px;
line-height:1.8;
color:var(--muted);
}

.buttons{
margin-top:40px;
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.primary,
.secondary{

display:inline-block;
padding:15px 28px;
border-radius:10px;
text-decoration:none;
font-weight:700;
transition:.3s;

}

.primary{
background:var(--primary);
color:white;
}

.primary:hover{
background:var(--primary-dark);
}

.secondary{
background:white;
border:1px solid var(--border);
color:var(--text);
}

section{
padding:80px 0;
}

section h2{
font-size:40px;
margin-bottom:25px;
}

section p{
font-size:18px;
line-height:1.9;
color:var(--muted);
}

.grid{

display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;

}

.card{

background:white;
padding:30px;
border-radius:18px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
transition:.35s;

}

.card:hover{

transform:translateY(-8px);

}

.card h3{

margin-bottom:15px;
color:var(--text);

}

.card p{

line-height:1.8;

}

.card ul{

padding-left:20px;
line-height:2;

}

.timeline{

display:flex;
justify-content:center;
align-items:center;
gap:10px;
flex-wrap:wrap;
margin-top:50px;

}

.step{

background:white;
padding:15px 20px;
border-radius:10px;
box-shadow:0 8px 20px rgba(0,0,0,.08);
font-weight:600;

}

.arrow{

font-size:28px;
color:var(--primary);

}

table{

width:100%;
margin-top:30px;
border-collapse:collapse;
overflow:hidden;

}

th{

background:var(--primary);
color:white;
padding:16px;

}

td{

padding:16px;
border:1px solid var(--border);

}

.related .card{

text-decoration:none;
color:inherit;

}

.related .card:hover{

color:var(--primary);

}

@media(max-width:900px){

.hero h1{

font-size:44px;

}

.hero p{

font-size:18px;

}

section h2{

font-size:32px;

}

.timeline{

flex-direction:column;

}

.arrow{

transform:rotate(90deg);

}

}

@media(max-width:600px){

.hero{

padding:70px 0;

}

.hero h1{

font-size:34px;

}

.hero p{

font-size:16px;

}

.buttons{

flex-direction:column;

}

.primary,
.secondary{

width:100%;
text-align:center;

}

.card{

padding:24px;

}

}

</style>
