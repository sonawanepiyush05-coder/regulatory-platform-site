<section class="standards">

<div class="container">

<h2>Important Standards Used in Medical Devices</h2>

<div class="grid">

<a href="/iso/iso-13485" class="card">
<h3>ISO 13485</h3>
<p>Quality Management System</p>
</a>

<a href="/iso/iso-14971" class="card">
