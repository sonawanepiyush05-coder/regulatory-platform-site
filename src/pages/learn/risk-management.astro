<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

:root{

--primary:#2563eb;
--primary-dark:#1d4ed8;
--background:#f8fafc;
--text:#0f172a;
--muted:#64748b;
--border:#e2e8f0;

}

body{

font-family:Inter,Arial,sans-serif;
background:var(--background);
color:var(--text);

}

.container{

width:min(1200px,92%);
margin:auto;

}


/* HERO */

.hero{

padding:90px 0;
background:linear-gradient(135deg,#eff6ff,#ffffff);
text-align:center;

}


.badge{

display:inline-block;
background:#dbeafe;
color:var(--primary);
padding:8px 18px;
border-radius:30px;
font-weight:700;
margin-bottom:20px;

}


.hero h1{

font-size:58px;
line-height:1.2;
margin-bottom:20px;

}


.hero p{

max-width:900px;
margin:auto;
font-size:19px;
color:var(--muted);
line-height:1.8;

}


/* BUTTONS */


.buttons{

display:flex;
justify-content:center;
gap:20px;
margin-top:40px;
flex-wrap:wrap;

}


.primary,
.secondary{

padding:14px 30px;
border-radius:10px;
text-decoration:none;
font-weight:700;
transition:.3s;

}


.primary{

background:var(--primary);
color:white;

}


.primary:hover{

background:var(--primary-dark);
transform:translateY(-3px);

}


.secondary{

background:white;
border:1px solid var(--border);
color:var(--text);

}


.secondary:hover{

background:#f1f5f9;

}


/* SECTION */


section{

padding:80px 0;

}


section h2{

font-size:38px;
margin-bottom:25px;

}


section p{

font-size:18px;
line-height:1.8;
color:var(--muted);

}


/* CARD GRID */


.grid{

display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
margin-top:35px;

}


.card{

background:white;
padding:30px;
border-radius:18px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
transition:.35s;

}


.card:hover{

transform:translateY(-8px);

}


.card h3{

font-size:22px;
margin-bottom:15px;

}


.card p{

font-size:16px;

}


.card ul{

padding-left:20px;

}


.card li{

margin-bottom:10px;

}


/* TABLE */


table{

width:100%;
border-collapse:collapse;
margin-top:35px;
background:white;
border-radius:15px;
overflow:hidden;

}


th{

background:#2563eb;
color:white;
padding:16px;
text-align:left;

}


td{

padding:16px;
border:1px solid #e2e8f0;
color:#334155;

}


tr:nth-child(even){

background:#f8fafc;

}


/* TIMELINE */


.timeline{

display:flex;
align-items:center;
justify-content:center;
gap:12px;
flex-wrap:wrap;
margin-top:40px;

}


.step{

background:white;
padding:16px 22px;
border-radius:12px;
font-weight:700;
box-shadow:0 8px 20px rgba(0,0,0,.08);
text-align:center;

}


.arrow{

font-size:28px;
color:var(--primary);
font-weight:bold;

}


/* LINKS */


a{

color:var(--primary);
font-weight:600;

}


a:hover{

text-decoration:underline;

}


ul{

line-height:2;
}


/* RESPONSIVE */


@media(max-width:900px){


.hero h1{

font-size:42px;

}


.hero p{

font-size:17px;

}


section h2{

font-size:30px;

}


.timeline{

flex-direction:column;

}


.arrow{

transform:rotate(90deg);

}


table{

display:block;
overflow-x:auto;
white-space:nowrap;

}


}


@media(max-width:600px){


.hero{

padding:60px 0;

}


.hero h1{

font-size:34px;

}


.hero p{

font-size:16px;

}


.buttons{

flex-direction:column;

}


.primary,
.secondary{

width:100%;
text-align:center;

}


.card{

padding:24px;

}


section{

padding:55px 0;

}


}


</style>