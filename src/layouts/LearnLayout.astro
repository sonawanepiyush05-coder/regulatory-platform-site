---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const { title } = Astro.props;
---

<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | ReguDocs</title>
</head>

<body>

<Navbar />

<main class="learn-page">

    <div class="container">

        <slot />

    </div>

</main>

<Footer />

</body>

</html>

<style>

.learn-page{
    background:#f8fbff;
    min-height:80vh;
    padding:70px 0;
}

.container{
    width:min(900px,90%);
    margin:auto;
    background:white;
    padding:50px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

h1{
    font-size:46px;
    color:#0f172a;
    margin-bottom:20px;
}

h2{
    margin-top:35px;
    color:#1e293b;
}

p{
    line-height:1.8;
    color:#475569;
    font-size:18px;
}

ul{
    padding-left:20px;
}

li{
    margin-bottom:10px;
    color:#475569;
}

</style>