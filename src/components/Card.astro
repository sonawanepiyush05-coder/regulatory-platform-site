---
interface Props {
  title: string;
  description: string;
  category?: string;
  link?: string;
}

const {
  title,
  description,
  category = "",
  link = "#"
} = Astro.props;
---

<a href={link} class="card">

  {category && (
    <span class="badge">{category}</span>
  )}

  <h3>{title}</h3>

  <p>{description}</p>

  <span class="more">
    Learn More →
  </span>

</a>

<style>

.card{

display:block;

background:white;

padding:28px;

border-radius:18px;

box-shadow:0 8px 20px rgba(0,0,0,.08);

transition:.3s;

text-decoration:none;

color:inherit;

}

.card:hover{

transform:translateY(-8px);

box-shadow:0 15px 30px rgba(37,99,235,.12);

}

.badge{

display:inline-block;

padding:6px 12px;

background:#dbeafe;

color:#2563eb;

border-radius:20px;

font-size:13px;

font-weight:bold;

margin-bottom:18px;

}

.card h3{

margin-bottom:12px;

font-size:24px;

}

.card p{

color:#64748b;

line-height:1.6;

margin-bottom:20px;

}

.more{

font-weight:bold;

color:#2563eb;

}

</style>