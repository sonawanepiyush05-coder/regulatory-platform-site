---
const { title, description, type, link } = Astro.props;
---

<div class="card">

  <span class="type">{type}</span>

  <h3>{title}</h3>

  <p>{description}</p>

  <a href={link}>
    Download →
  </a>

</div>

<style>

.card{
  background:white;
  padding:30px;
  border-radius:18px;
  box-shadow:0 10px 25px rgba(0,0,0,.08);
  transition:.3s;
  display:flex;
  flex-direction:column;
}

.card:hover{
  transform:translateY(-8px);
  box-shadow:0 15px 35px rgba(37,99,235,.12);
}

.type{
  display:inline-block;
  width:max-content;
  padding:6px 12px;
  background:#dbeafe;
  color:#2563eb;
  border-radius:20px;
  font-size:13px;
  font-weight:700;
  margin-bottom:15px;
}

.card h3{
  margin:0 0 12px;
  color:#0f172a;
  font-size:22px;
}

.card p{
  color:#64748b;
  line-height:1.7;
  margin-bottom:25px;
  flex:1;
}

.card a{
  color:#2563eb;
  text-decoration:none;
  font-weight:700;
}

.card a:hover{
  text-decoration:underline;
}

</style>