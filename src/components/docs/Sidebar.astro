---
import { standards } from "../../data/standards";
---

<aside class="sidebar">

    <h3>ISO Standards</h3>

    <nav>

        {
            standards.map((standard) => (

                <a href={standard.url}>
                    {standard.title}
                </a>

            ))
        }

    </nav>

</aside>

<style>

.sidebar{

position:fixed;

left:0;

top:82px;

width:260px;

height:calc(100vh - 82px);

background:white;

padding:30px 20px;

border-right:1px solid #e5e7eb;

overflow-y:auto;

}

.sidebar h3{

margin-bottom:20px;

font-size:22px;

color:#0f172a;

}

.sidebar nav{

display:flex;

flex-direction:column;

gap:14px;

}

.sidebar a{

text-decoration:none;

color:#475569;

padding:10px 14px;

border-radius:10px;

transition:.3s;

font-weight:500;

}

.sidebar a:hover{

background:#dbeafe;

color:#2563eb;

}

@media(max-width:900px){

.sidebar{

display:none;

}

}

</style>